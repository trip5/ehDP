# PlatformIO package publishing exclusions
# Only include: /examples, /include, /src, README.md, library.json, library.properties, LICENSE

# Exclude GitHub workflows and config
.github/ export-ignore
.gitattributes export-ignore
.gitignore export-ignore

# Exclude other platform implementations
components/ export-ignore
ESPHome/ export-ignore
Tasmota-Berry/ export-ignore
python/ export-ignore

# Exclude documentation and notes not needed in the Arduino/PlatformIO package
SPEC_1.md export-ignore
Notes.txt export-ignore
